# ══════════════════════════════════════════════════════════════
#  TOTEM SYNC WORKER — Variáveis de Ambiente
#  Copie este arquivo para .env na pasta do totem local
#  e preencha os valores abaixo.
# ══════════════════════════════════════════════════════════════

# URL do Hub publicado (sem barra no final)
# Ex: https://meu-totem.lovable.app  ou  https://id--preview.lovable.app
HUB_URL=https://SEU-HUB-AQUI.lovable.app

# Caminho absoluto da pasta local do totem (onde estão App.jsx, etc.)
# Se não definir, usa o diretório onde sync-worker.js está.
# LOCAL_DIR=/home/pi/totem

# Intervalo de verificação em milissegundos (padrão: 30 segundos)
SYNC_INTERVAL_MS=30000

# Comando para reiniciar o totem automaticamente após arquivos críticos serem atualizados.
# Exemplos:
#   pm2 restart totem
#   systemctl restart totem
#   npm run dev   (apenas em desenvolvimento)
# RESTART_COMMAND=pm2 restart totem

# Manter backup (.bak) dos arquivos antes de substituir (true/false)
BACKUP_FILES=true

# Logs detalhados (true/false)
VERBOSE=false
