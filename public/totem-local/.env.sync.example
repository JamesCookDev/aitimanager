# ══════════════════════════════════════════════════════════════
#  TOTEM LOCAL — Configuração Mínima (Auto-Registro)
#  Copie este arquivo para .env na pasta do totem local.
#  ⚡ Com auto-registro, NÃO precisa de DEVICE_ID nem API_KEY!
# ══════════════════════════════════════════════════════════════

# ── Obrigatório (igual para TODOS os totems da mesma org) ────

# URL das Edge Functions do projeto
VITE_CMS_API_URL=https://iwqcltmeniotzbowbxzg.supabase.co/functions/v1

# Anon key do projeto (mesma para TODOS os totems)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Iml3cWNsdG1lbmlvdHpib3dieHpnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE0NDQ0NDUsImV4cCI6MjA4NzAyMDQ0NX0.IxBMzeC6VUhe8lRE0yELuZM-4YdzgBo5dsCdddp1C_s

# URL base do Supabase (para Realtime)
VITE_SUPABASE_URL=https://iwqcltmeniotzbowbxzg.supabase.co

# ID da organização (mesmo para todos os totems da mesma org)
VITE_ORG_ID=cole-o-uuid-da-organizacao-aqui

# ── Opcional (auto-registro preenche automaticamente) ────────

# Se quiser nomear o totem no registro (senão usa hostname/ID gerado)
# VITE_TOTEM_NAME=Totem Recepção
# VITE_TOTEM_LOCATION=Entrada Principal

# Se já tiver um device_id (pula auto-registro):
# VITE_TOTEM_DEVICE_ID=uuid-do-dispositivo

# ── Sync Worker ──────────────────────────────────────────────

# URL do Hub publicado
HUB_URL=https://aitimanager.lovable.app

# Pasta local do frontend (onde os arquivos são sincronizados)
LOCAL_DIR=.

# Pasta do backend local (relativo ao LOCAL_DIR ou caminho absoluto)
# Se não definido, assume ../backend relativo ao LOCAL_DIR
# BACKEND_DIR=../backend

# Intervalo de sync em ms
SYNC_INTERVAL_MS=30000

# RESTART_COMMAND=npm run dev
BACKUP_FILES=true
VERBOSE=true

# ── Kiosk (navegador em tela cheia) ──────────────────────────

# URL que o kiosk abre (padrão: http://localhost:5173)
# KIOSK_URL=http://localhost:5173

# Delay antes de abrir o navegador em ms (aguarda servidores iniciarem)
# KIOSK_DELAY_MS=8000

# Caminho do navegador (padrão: auto-detecta Edge/Chrome)
# KIOSK_BROWSER=auto

# ── Chat IA — Backend Local (opcional) ───────────────────────
VITE_API_URL=http://localhost:3000
