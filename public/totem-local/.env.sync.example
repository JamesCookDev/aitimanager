# ══════════════════════════════════════════════════════════════
#  TOTEM LOCAL — Configuração (v6.0)
#  Worker busca HTML publicado via Edge Function e serve localmente.
# ══════════════════════════════════════════════════════════════

# ── Obrigatório ──────────────────────────────────────────────

# URL das Edge Functions do projeto
VITE_CMS_API_URL=https://iwqcltmeniotzbowbxzg.supabase.co/functions/v1

# Anon key do projeto
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Iml3cWNsdG1lbmlvdHpib3dieHpnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE0NDQ0NDUsImV4cCI6MjA4NzAyMDQ0NX0.IxBMzeC6VUhe8lRE0yELuZM-4YdzgBo5dsCdddp1C_s

# URL base do Supabase (para comandos remotos)
VITE_SUPABASE_URL=https://iwqcltmeniotzbowbxzg.supabase.co

# ID do dispositivo (obtenha no Hub → Dispositivos)
VITE_TOTEM_DEVICE_ID=cole-o-uuid-do-dispositivo-aqui

# OU use a API key do dispositivo (alternativa ao device ID)
# API_KEY=cole-a-api-key-aqui

# ── Servidor HTTP ────────────────────────────────────────────

# Porta do servidor local (padrão: 8080)
HTTP_PORT=8080

# ── Polling ──────────────────────────────────────────────────

# Intervalo de verificação de atualizações em ms (padrão: 15000)
SYNC_INTERVAL_MS=15000

# ── Kiosk (navegador em tela cheia) ──────────────────────────

# URL que o kiosk abre (padrão: http://localhost:8080)
# KIOSK_URL=http://localhost:8080

# Delay antes de abrir o navegador em ms
# KIOSK_DELAY_MS=3000

# Caminho do navegador (padrão: auto-detecta Edge/Chrome)
# KIOSK_BROWSER=auto

# ── Debug ────────────────────────────────────────────────────
VERBOSE=true
