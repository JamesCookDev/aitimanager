# ══════════════════════════════════════════════════════════════
#  TOTEM LOCAL — .env (copie este arquivo para .env)
#  Configure os valores abaixo antes de rodar: yarn dev
# ══════════════════════════════════════════════════════════════

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  1. CONEXÃO COM O HUB (obrigatório)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# URL das Edge Functions do projeto
VITE_CMS_API_URL=https://iwqcltmeniotzbowbxzg.supabase.co/functions/v1

# URL base do Supabase (para Realtime e heartbeat)
VITE_SUPABASE_URL=https://iwqcltmeniotzbowbxzg.supabase.co

# Anon key do projeto (mesma para TODOS os totems)
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Iml3cWNsdG1lbmlvdHpib3dieHpnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE0NDQ0NDUsImV4cCI6MjA4NzAyMDQ0NX0.IxBMzeC6VUhe8lRE0yELuZM-4YdzgBo5dsCdddp1C_s

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  2. IDENTIDADE DO TOTEM (escolha UMA opção)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# OPÇÃO A — Auto-registro (recomendado para novas máquinas)
# Basta informar o ORG_ID e o totem se registra sozinho no primeiro boot.
# Copie o ORG_ID da página Organizações no Hub.
VITE_ORG_ID=cole-o-uuid-da-organizacao-aqui

# OPÇÃO B — Dispositivo já registrado (pula auto-registro)
# Use se já criou o dispositivo manualmente no Hub.
# VITE_TOTEM_DEVICE_ID=cole-o-uuid-do-dispositivo-aqui
# VITE_TOTEM_API_KEY=cole-a-api-key-do-dispositivo-aqui

# Nome e local do totem (opcional, usado no auto-registro)
# VITE_TOTEM_NAME=Totem Recepção
# VITE_TOTEM_LOCATION=Entrada Principal

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  3. POLLING E SYNC (opcional)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# Intervalo de polling da config do Hub em ms (padrão: 15000)
VITE_CMS_POLL_INTERVAL=15000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  3b. INSTALAÇÃO AUTOMÁTICA (opcional)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# O sync-worker instala dependências automaticamente quando:
#   - node_modules não existe (primeira instalação)
#   - package.json é atualizado pelo Hub
# Para desativar: AUTO_INSTALL=false
AUTO_INSTALL=true

# Forçar gerenciador de pacotes (yarn, npm, pnpm). Padrão: auto-detecta
# PACKAGE_MANAGER=yarn

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  4. IA LOCAL — Backend (opcional)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# Se tiver Ollama + Kokoro rodando localmente, descomente:
# VITE_API_URL=http://localhost:3000

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  5. SYNC WORKER (para sync-worker.js, não para yarn dev)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# URL do Hub publicado
HUB_URL=https://aitimanager.lovable.app

# Intervalo de sync em ms
SYNC_INTERVAL_MS=30000

# Backup antes de sobrescrever arquivos
BACKUP_FILES=true

# Logs detalhados
VERBOSE=false

# Comando para reiniciar após sync de arquivos críticos
# RESTART_COMMAND=pm2 restart totem

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  6. BACKEND LOCAL — server.js (obrigatório se usar IA local)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# ⚠️ O server.js NÃO usa prefixo VITE_. Configure estas variáveis
# para que o backend se conecte ao Hub e envie heartbeat.

# Conexão do backend com o Hub (sem prefixo VITE_)
SUPABASE_URL=https://iwqcltmeniotzbowbxzg.supabase.co
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Iml3cWNsdG1lbmlvdHpib3dieHpnIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzE0NDQ0NDUsImV4cCI6MjA4NzAyMDQ0NX0.IxBMzeC6VUhe8lRE0yELuZM-4YdzgBo5dsCdddp1C_s

# API Key do dispositivo (gerada automaticamente no auto-registro)
# → Rode o frontend primeiro (yarn dev), copie o api_key do console/localStorage
TOTEM_API_KEY=cole-a-api-key-gerada-no-registro

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
#  7. CHAVES DE IA (opcional)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━

# GROQ_API_KEY=sua-chave-groq
# HF_TOKEN=seu-token-huggingface

# Kokoro TTS (local)
# KOKORO_BASE_URL=http://localhost:8880
# KOKORO_VOICE=pm_alex
# KOKORO_SPEED=1
# KOKORO_MODEL=kokoro
